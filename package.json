{
  "name": "automatizacion",
  "version": "1.0.0",
  "description": "Framework de automatizacion de Playwright, cucumber y typescript",
  "main": "index.js",
  "scripts": {
    "multipleNavegador": "ts-node runner.ts",
    "test:ui": "npx playwright test --ui",
    "chrome": "ts-node runner.ts browser=chromium",
    "edge": "ts-node runner.ts browser=edge",
    "firefox": "ts-node runner.ts browser=firefox",
    "safari": "ts-node runner.ts browser=webkit",
    "api": "ts-node runner.ts browser=api",
    "perf": "node ejecucionPerformance.js",
    "install:k6": "node instalarK6.js",
    "install:playwright": "npx playwright install --with-deps",
    "postinstall": "npm-run-all install:k6 install:playwright"
  },
  "keywords": [
    "automation",
    "testing",
    "playwright",
    "cucumber"
  ],
  "author": "Yorhan Polanco",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/k6": "^1.0.2",
    "@types/node": "^22.5.0",
    "@types/oracledb": "^6.5.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "playwright-bdd": "^8.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "automatizacion": "file:",
    "dayjs": "^1.11.13",
    "dot-path-value": "^0.0.11",
    "npm": "^11.6.0",
    "npm-run-all": "^4.1.5",
    "oracledb": "^6.6.0",
    "playwright": "^1.50.1",
    "sharp": "^0.33.5"
  }
}